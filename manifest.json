{
  "manifest_version": 2,
  "name": "GAFAM Tracker",
  "version": "1.0",
  "description": "Trackt, wie viel Zeit du auf GAFAM-Websites verbringst.",
  "permissions": ["tabs", "storage", "windows", "alarms", "<all_urls>"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["overlay/live_status_overlay.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/gafam-tracker-icon.svg",
      "48": "icons/gafam-tracker-icon.svg",
      "128": "icons/gafam-tracker-icon.svg"
    }
  },
  "icons": {
    "16": "icons/gafam-tracker-icon.svg",
    "48": "icons/gafam-tracker-icon.svg",
    "128": "icons/gafam-tracker-icon.svg"
  }
}